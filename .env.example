# ============ ספק נתוני מקומות ============
# sample      - נתוני הדוגמה שברפו (ברירת מחדל, בלי מפתחות)
# google      - העשרה וחיפוש דרך Google Places API (New)
# tripadvisor - חיפוש דרך TripAdvisor Content API
NEXT_PUBLIC_PLACES_PROVIDER=sample

# Google Places API (New) - console.cloud.google.com
# GOOGLE_PLACES_API_KEY=

# TripAdvisor Content API - developer.tripadvisor.com (5,000 קריאות חינם בחודש)
# TRIPADVISOR_API_KEY=

# ============ צ׳אט AI ============
# בלי מפתח: הצ׳אט עובד עם מנוע חוקים מעל הדאטה המקומי.
# עם מפתח: תשובות Claude בעברית בסטרימינג, מעוגנות בדאטה של היעדים,
# עם prompt caching כך שהודעות חוזרות מהירות וזולות משמעותית.
# ANTHROPIC_API_KEY=
#
# בחירת מודל:
#   claude-sonnet-4-5 - ברירת המחדל החכמה (איכות תשובות גבוהה)
#   claude-haiku-4-5  - האופציה המהירה והזולה (טוב לפיתוח ולעומסים)
# ANTHROPIC_MODEL=claude-sonnet-4-5
